# Cascade — AI Voice Tutor
# Copy this file to .env and fill in your API keys

# Deepgram — Speech-to-Text (required)
# Get your key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq — LLM Inference (required)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional Security & Deployment Settings ─────────────────────────────────

# HMAC Authentication Secret (optional)
# If set, clients must complete a SHA-256 challenge-response before the pipeline
# starts. Leave unset for open local development.
# CASCADE_AUTH_SECRET=your_secret_here

# CORS Allowed Origins (optional)
# Comma-separated list of origins allowed to call the HTTP API.
# Default: * (all origins, suitable for local dev only).
# Production example: CASCADE_CORS_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com
# CASCADE_CORS_ORIGINS=*

# Maximum Concurrent WebSocket Sessions (optional, default: 5)
# CASCADE_MAX_CONCURRENT_SESSIONS=5

# STT Endpointing Window in ms (optional, default: 300)
# CASCADE_STT_ENDPOINTING=300

# Advanced Speech-to-Speech Tunables
# CASCADE_VAD_THRESHOLD=0.5
# CASCADE_VAD_SILENCE_MS=200
# CASCADE_SPECULATIVE_GRACE_MS=180
# CASCADE_INTERIM_TRIGGER_WORDS=6

# Max History Turns (optional, default: 10)
# CASCADE_MAX_HISTORY_TURNS=10

# Idle Timeout in Seconds (optional, default: 300)
# CASCADE_IDLE_TIMEOUT_SEC=300
